PORT=3000
APP_BASE_URL=http://localhost:3000
NODE_ENV=development
ADMIN_PASSWORD=change-me
APP_ENCRYPTION_KEY=replace-with-a-random-64-character-hex-value
DATABASE_PATH=./data/followpilot.db

# Demo mode makes the full local flow testable without third-party credentials.
DEMO_MODE=true

# Avoma
AVOMA_API_KEY=
AVOMA_API_BASE_URL=https://api.avoma.com/v1
AVOMA_WEBHOOK_SECRET=replace-with-a-long-random-secret
INTERNAL_DOMAINS=yourcompany.com

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Slack app (enable interactivity and add chat:write, im:write, files:read)
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_FALLBACK_CHANNEL=
# JSON object mapping meeting-owner email to Slack user ID.
AE_SLACK_MAP={"ae@yourcompany.com":"U0123456789"}

# Microsoft Entra app
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:3000/auth/microsoft/callback

# Draft defaults
EMAIL_TONE=warm, concise, specific, and professional
EMAIL_MAX_WORDS=220
EMAIL_TEMPLATE=Thank them briefly. Recap the most relevant needs and decisions. List clear next steps with owners. End with one natural call to action.
DEFAULT_CC=
HUBSPOT_ENABLED=false
HUBSPOT_ACCESS_TOKEN=
HUBSPOT_API_BASE_URL=https://api.hubapi.com
